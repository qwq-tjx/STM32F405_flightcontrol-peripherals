        // ===================== MAVLink 订阅 =====================
        private void SubscribeMavlink()
        {
            try
            {
                if (MainV2.comPort != null)
                {
                    MainV2.comPort.OnPacketReceived += OnMavlinkPacket;
                }
            }
            catch { /* 首次加载时 comPort 可能尚未初始化 */ }

            // 如果初始订阅失败，延迟重试
            var retryTimer = new System.Windows.Forms.Timer { Interval = 2000 };
            retryTimer.Tick += (s, e) =>
            {
                try
                {
                    if (MainV2.comPort != null)
                    {
                        MainV2.comPort.OnPacketReceived -= OnMavlinkPacket;
                        MainV2.comPort.OnPacketReceived += OnMavlinkPacket;
                        retryTimer.Stop();
                        retryTimer.Dispose();
                    }
                }
                catch { }
            };
            retryTimer.Start();
        }

        private void OnMavlinkPacket(object sender, MAVLink.MAVLinkMessage msg)
        {
            switch (msg.msgid)
            {
                case (uint)MAVLink.MAVLINK_MSG_ID.ATTITUDE:
                {
                    var att = (MAVLink.mavlink_attitude_t)msg.data;
                    lock (_lock)
                    {
                        _roll       = att.roll  * 57.29578f;  // rad -> deg
                        _pitch      = att.pitch * 57.29578f;
                        _yaw        = att.yaw   * 57.29578f;
                        _rollSpeed  = att.rollspeed;
                        _pitchSpeed = att.pitchspeed;
                        _yawSpeed   = att.yawspeed;
                        _hasAttitude = true;
                    }
                    break;
                }

                case (uint)MAVLink.MAVLINK_MSG_ID.HIGHRES_IMU:
                {
                    var imu = (MAVLink.mavlink_highres_imu_t)msg.data;
                    lock (_lock)
                    {
                        _accX = imu.xacc;
                        _accY = imu.yacc;
                        _accZ = imu.zacc;
                        _gyroX = imu.xgyro;
                        _gyroY = imu.ygyro;
                        _gyroZ = imu.zgyro;
                        _magX = imu.xmag;
                        _magY = imu.ymag;
                        _magZ = imu.zmag;
                        _imuTemperature = imu.temperature;
                        _hasHighresImu = true;
                    }
                    break;
                }

                case (uint)MAVLink.MAVLINK_MSG_ID.ATTITUDE_QUATERNION:
                {
                    var quat = (MAVLink.mavlink_attitude_quaternion_t)msg.data;
                    lock (_lock)
                    {
                        _qw = quat.q1;
                        _qx = quat.q2;
                        _qy = quat.q3;
                        _qz = quat.q4;
                        _hasQuaternion = true;
                    }
                    break;
                }

                case (uint)MAVLink.MAVLINK_MSG_ID.SCALED_PRESSURE:
                {
                    var pres = (MAVLink.mavlink_scaled_pressure_t)msg.data;
                    lock (_lock)
                    {
                        _pressure = pres.press_abs;
                        _hasPressure = true;
                    }
                    break;
                }

                case (uint)MAVLink.MAVLINK_MSG_ID.ALTITUDE:
                {
                    var alt = (MAVLink.mavlink_altitude_t)msg.data;
                    lock (_lock)
                    {
                        _altMonotonic = alt.altitude_monotonic;
                        _altAmsl      = alt.altitude_amsl;
                        _altLocal     = alt.altitude_local;
                        _altRelative  = alt.altitude_relative;
                        _hasAltitude  = true;
                    }
                    break;
                }
            }
        }

        // ===================== 定时刷新 UI =====================
        private void OnRefresh(object sender, EventArgs e)
        {
            if (_chkPause.Checked) return;

            float r, p, y, rs, ps, ys, ax, ay, az, gx, gy, gz, mx, my, mz;
            float qw, qx, qy, qz, press, imuTemp, altRel, altAmsl;
            bool hasAtt, hasQuat;

            lock (_lock)
            {
                r = _roll;  p = _pitch;  y = _yaw;
                rs = _rollSpeed;  ps = _pitchSpeed;  ys = _yawSpeed;
                ax = _accX;  ay = _accY;  az = _accZ;
                gx = _gyroX;  gy = _gyroY;  gz = _gyroZ;
                mx = _magX;  my = _magY;  mz = _magZ;
                qw = _qw;  qx = _qx;  qy = _qy;  qz = _qz;
                press = _pressure;  imuTemp = _imuTemperature;
                altRel = _altRelative;  altAmsl = _altAmsl;
                hasAtt = _hasAttitude;
                hasQuat = _hasQuaternion;
            }

            // 更新状态栏
            _statusLabel.Text = hasAtt
                ? string.Format("数据接收正常 | Roll:{0:+0.0;-0.0}° Pitch:{1:+0.0;-0.0}° Yaw:{2:+0.0;-0.0}° | IMU:{3:0.0}°C", r, p, y, imuTemp)
                : "等待 MAVLink 数据...";

            // 更新数值面板
            _anglePanel.SetValues(new[] { r, p, y });
            _gyroPanel.SetValues(new[] { rs, ps, ys });
            _accelPanel.SetValues(new[] { ax, ay, az });
            _magPanel.SetValues(new[] { mx, my, mz });
            _quatPanel.SetValues(new[] { qw, qx, qy, qz });
            _pressurePanel.SetValues(new[] { press, imuTemp });
            _altitudePanel.SetValues(new[] { altRel, altAmsl });

            // 更新曲线图
            _attitudeChart.AddData(new[] { r, p, y });
            _imuChart.AddData(new[] { ax, ay, az, gx, gy, gz });
            _altPressureChart.AddData(new[] { press, altRel, altAmsl });
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            if (_refreshTimer != null) _refreshTimer.Stop();
            try { MainV2.comPort.OnPacketReceived -= OnMavlinkPacket; } catch { }
            base.OnFormClosing(e);
        }
