    public class ChartSeries
    {
        public string Name;
        public Color  Color;
        public ChartSeries(string name, Color color) { Name = name; Color = color; }
    }

    public class TimeSeriesChart : Control
    {
        private readonly string _title;
        private readonly int _maxPoints;
        private Queue<float[]> _buffer = new Queue<float[]>();
        public ChartSeries[] Series;

        public TimeSeriesChart(string title, int maxPoints)
        {
            _title = title;
            _maxPoints = maxPoints;
            this.DoubleBuffered = true;
            this.BackColor = Color.FromArgb(50, 50, 58);
        }

        public void AddData(float[] values)
        {
            _buffer.Enqueue(values);
            while (_buffer.Count > _maxPoints)
                _buffer.Dequeue();
            this.Invalidate();
        }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            var g = e.Graphics;
            g.SmoothingMode = SmoothingMode.AntiAlias;

            int w = this.Width, h = this.Height;

            // 背景
            using (var path = RoundedRect(0, 0, w, h, 8))
            using (var bgBrush = new SolidBrush(this.BackColor))
                g.FillPath(bgBrush, path);

            // 标题
            using (var font = new Font("Segoe UI", 10, FontStyle.Bold))
            using (var brush = new SolidBrush(Color.FromArgb(180, 180, 190)))
                g.DrawString(_title, font, brush, 10, 6);

            // 图例
            if (Series != null)
            {
                int lx = w - 10;
                using (var legendFont = new Font("Segoe UI", 7.5f))
                {
                    for (int i = Series.Length - 1; i >= 0; i--)
                    {
                        string text = Series[i].Name;
                        var sz = g.MeasureString(text, legendFont);
                        lx -= (int)sz.Width + 18;
                        using (var dotBrush = new SolidBrush(Series[i].Color))
                            g.FillEllipse(dotBrush, lx + 2, 9, 7, 7);
                        using (var textBrush = new SolidBrush(Series[i].Color))
                            g.DrawString(text, legendFont, textBrush, lx + 12, 8);
                    }
                }
            }

            // 绘图区域
            int marginLeft = 45, marginRight = 15, marginTop = 32, marginBottom = 20;
            int plotW = w - marginLeft - marginRight;
            int plotH = h - marginTop - marginBottom;

            if (plotW <= 0 || plotH <= 0 || _buffer.Count < 2 || Series == null) return;

            // 边框
            using (var pen = new Pen(Color.FromArgb(70, 70, 78), 1f))
            {
                g.DrawRectangle(pen, marginLeft, marginTop, plotW, plotH);
            }

            // 网格线
            using (var gridPen = new Pen(Color.FromArgb(45, 45, 52), 0.5f))
            {
                for (int i = 1; i <= 3; i++)
                {
                    int gy = marginTop + plotH * i / 4;
                    g.DrawLine(gridPen, marginLeft, gy, marginLeft + plotW, gy);
                }
            }

            // 计算 Y 轴范围
            float yMin = float.MaxValue, yMax = float.MinValue;
            foreach (var arr in _buffer)
                foreach (var v in arr)
                {
                    if (v < yMin) yMin = v;
                    if (v > yMax) yMax = v;
                }
            if (Math.Abs(yMax - yMin) < 0.001f) { yMin -= 1; yMax += 1; }
            float yRange = yMax - yMin;
            yMin -= yRange * 0.05f;
            yMax += yRange * 0.05f;
            yRange = yMax - yMin;

            // Y 轴标签
            using (var labelFont = new Font("Segoe UI", 7))
            using (var labelBrush = new SolidBrush(Color.FromArgb(140, 140, 150)))
            {
                for (int i = 0; i <= 4; i++)
                {
                    float val = yMax - yRange * i / 4;
                    string text = val.ToString("F1");
                    var sz = g.MeasureString(text, labelFont);
                    int yPos = marginTop + plotH * i / 4;
                    g.DrawString(text, labelFont, labelBrush, marginLeft - sz.Width - 4, yPos - sz.Height / 2);
                }
            }

            // 绘制曲线
            float[][] history = _buffer.ToArray();
            int count = history.Length;

            if (Series != null)
            {
                for (int s = 0; s < Series.Length; s++)
                {
                    if (s >= history[0].Length) continue;

                    var pts = new PointF[count];
                    for (int i = 0; i < count; i++)
                    {
                        float x = marginLeft + (float)i / (_maxPoints - 1) * plotW;
                        float y = marginTop + plotH - (history[i][s] - yMin) / yRange * plotH;
                        pts[i] = new PointF(x, y);
                    }

                    using (var pen = new Pen(Series[s].Color, 1.5f))
                        g.DrawLines(pen, pts);
                }
            }

            // 最新值
            if (count > 0 && Series != null)
            {
                var latest = history[count - 1];
                using (var valFont = new Font("Consolas", 8))
                {
                    for (int s = 0; s < Math.Min(Series.Length, latest.Length); s++)
                    {
                        float y = marginTop + plotH - (latest[s] - yMin) / yRange * plotH;
                        using (var brush = new SolidBrush(Series[s].Color))
                        {
                            g.FillEllipse(brush, marginLeft + plotW - 4, y - 3, 7, 7);
                        }
                    }
                }
            }
        }

        private GraphicsPath RoundedRect(int x, int y, int w, int h, int r)
        {
            var path = new GraphicsPath();
            int d = r * 2;
            path.AddArc(x, y, d, d, 180, 90);
            path.AddArc(x + w - d, y, d, d, 270, 90);
            path.AddArc(x + w - d, y + h - d, d, d, 0, 90);
            path.AddArc(x, y + h - d, d, d, 90, 90);
            path.CloseFigure();
            return path;
        }
    }
}
