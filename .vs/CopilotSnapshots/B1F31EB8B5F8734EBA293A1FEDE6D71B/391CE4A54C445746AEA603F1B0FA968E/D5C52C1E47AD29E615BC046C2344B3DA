    public class ImuValuePanel : Control
    {
        private string _title;
        private float[] _values = new float[0];
        public ImuValueRow[] Rows;

        public ImuValuePanel(string title)
        {
            _title = title;
            this.DoubleBuffered = true;
            this.BackColor = Color.FromArgb(50, 50, 58);
        }

        public void SetValues(float[] values)
        {
            _values = values;
            this.Invalidate();
        }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            var g = e.Graphics;
            g.SmoothingMode = SmoothingMode.AntiAlias;

            int w = this.Width, h = this.Height;

            // 背景圆角矩形
            using (var path = RoundedRect(0, 0, w, h, 8))
            using (var bgBrush = new SolidBrush(this.BackColor))
                g.FillPath(bgBrush, path);

            // 标题
            using (var titleFont = new Font("Segoe UI", 10, FontStyle.Bold))
            using (var titleBrush = new SolidBrush(Color.FromArgb(180, 180, 190)))
                g.DrawString(_title, titleFont, titleBrush, 10, 6);

            // 分隔线
            using (var pen = new Pen(Color.FromArgb(80, 80, 88), 1f))
                g.DrawLine(pen, 10, 28, w - 10, 28);

            if (Rows == null || _values.Length == 0) return;

            int startY = 34;
            int rowH = Math.Min(36, (h - startY - 4) / Math.Max(1, Rows.Length));

            for (int i = 0; i < Math.Min(Rows.Length, _values.Length); i++)
            {
                int y = startY + i * rowH;
                float val = _values[i];

                // 标签
                using (var font = new Font("Segoe UI", 9))
                using (var brush = new SolidBrush(Color.FromArgb(160, 160, 170)))
                {
                    var sz = g.MeasureString(Rows[i].Label, font);
                    g.DrawString(Rows[i].Label, font, brush, 10, y + (rowH - sz.Height) / 2);
                }

                // 数值
                using (var valFont = new Font("Consolas", 14, FontStyle.Bold))
                using (var valBrush = new SolidBrush(Rows[i].Color))
                {
                    string text = val.ToString("F3");
                    var sz = g.MeasureString(text, valFont);
                    g.DrawString(text, valFont, valBrush, w - 10 - sz.Width, y + (rowH - sz.Height) / 2);
                }

                // 进度条背景
                int barX = 80;
                int barW = w - 80 - 140;
                int barY = y + rowH - 8;
                int barH = 5;
                if (barW > 20)
                {
                    using (var barBg = new SolidBrush(Color.FromArgb(60, 60, 68)))
                        g.FillRectangle(barBg, barX, barY, barW, barH);

                    float absVal = Math.Abs(val);
                    float maxVal = 10f;
                    // 行级特殊范围 (优先)
                    if (Rows[i].Label.Contains("温度")) maxVal = 100f;
                    else if (_title.Contains("角速度")) maxVal = 6.28f;
                    else if (_title.Contains("加速度")) maxVal = 20f;
                    else if (_title.Contains("欧拉角") || _title.Contains("姿态")) maxVal = 180f;
                    else if (_title.Contains("四元数")) maxVal = 1f;
                    else if (_title.Contains("气压")) maxVal = 2000f;
                    else if (_title.Contains("高度")) maxVal = 500f;
                    else if (_title.Contains("磁力计")) maxVal = 2f;

                    int fillW = (int)(Math.Min(absVal, maxVal) / maxVal * barW);
                    using (var fillBrush = new SolidBrush(Color.FromArgb(80, Rows[i].Color)))
                        g.FillRectangle(fillBrush, barX, barY, fillW, barH);
                }
            }
        }

        private GraphicsPath RoundedRect(int x, int y, int w, int h, int r)
        {
            var path = new GraphicsPath();
            int d = r * 2;
            path.AddArc(x, y, d, d, 180, 90);
            path.AddArc(x + w - d, y, d, d, 270, 90);
            path.AddArc(x + w - d, y + h - d, d, d, 0, 90);
            path.AddArc(x, y + h - d, d, d, 90, 90);
            path.CloseFigure();
            return path;
        }
    }

